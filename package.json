{
  "name": "chatpro-overlay",
  "version": "1.9.0",
  "description": "ChatPro — German reply overlay for OnlyFans chatters",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:all": "electron-builder --win --mac --x64"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "axios": "^1.15.0",
    "chokidar": "^5.0.0",
    "electron-store": "^8.2.0",
    "form-data": "^4.0.5",
    "node-machine-id": "^1.1.12",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.chatpro.overlay",
    "productName": "ChatPro Overlay",
    "copyright": "Copyright © 2024 ChatPro",
    "files": [
      "src/**/*",
      "assets/**/*",
      "modelsheet.html",
      "schulung.html"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ChatPro Overlay"
    },
    "dmg": {
      "title": "ChatPro",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "artifactName": "ChatPro-Mac-${arch}.dmg",
      "writeUpdateInfo": false
    },
    "icon": "assets/icon.png",
    "linux": {
      "icon": "assets/icon.png"
    }
  }
}